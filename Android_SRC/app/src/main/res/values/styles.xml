<resources>

    <!-- Base application theme. -->
    <style name="AppTheme" parent="Theme.AppCompat.Light.NoActionBar">
        <!-- Customize your theme here. -->
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>
        <!-- Customize your theme here. -->
        <item name="android:windowBackground">@color/splash_background_color</item>
        <item name="android:statusBarColor">@color/splash_status_bar_color</item>
    </style>

    <style name="FullscreenTheme" parent="AppTheme">
        <item name="android:actionBarStyle">@style/FullscreenActionBarStyle</item>


        <!-- Customize your theme here. -->
        <item name="android:windowBackground">@color/theme_default_bg</item>
        <!-- Transparent system bars so the container's background shows through and
             the JS-driven theme switch can repaint the status/navigation areas. -->
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
    </style>

    <style name="FullscreenActionBarStyle" parent="Widget.AppCompat.ActionBar">
        <!-- Customize your theme here. -->
        <item name="android:windowBackground">@color/splash_background_color</item>
        <item name="android:statusBarColor">@color/splash_status_bar_color</item>
    </style>

</resources>
